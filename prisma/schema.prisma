generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  READER
}

enum CopyStatus {
  AVAILABLE
  LOANED
  RESERVED
  MAINTENANCE
}

enum LoanStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

enum LoanRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ConsentMethod {
  ADMIN_REGISTRATION
  SELF_ACCEPTANCE
}

enum DataSubjectRequestType {
  ACCESS
  CORRECTION
  DELETION
  PORTABILITY
  REVOCATION
  INFORMATION
}

enum DataSubjectRequestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum EmailVerificationPurpose {
  USER_SIGNUP
}

/// Tipo de obra no contexto espírita
enum SpiritWorkType {
  CODIFICATION
  PSYCHOGRAPHED
  DICTATED
  COMPILATION
  BIOGRAPHY
  STUDY
  OTHER
}

model User {
  id                   String         @id @default(cuid())
  name                 String
  email                String         @unique
  cpf                  String?        @unique
  password             String
  role                 Role           @default(READER)
  privacyAcceptedAt    DateTime?
  privacyPolicyVersion String?
  termsAcceptedAt      DateTime?
  termsVersion         String?
  consentRecordedById  String?
  consentMethod        ConsentMethod?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  loans                Loan[]
  loanRequests         LoanRequest[]
  reviewedLoanRequests LoanRequest[] @relation("LoanRequestReviewedBy")

  accounts            Account[]
  sessions            Session[]
  consentRecordedBy   User?                @relation("UserConsent", fields: [consentRecordedById], references: [id], onDelete: SetNull)
  consentedUsers      User[]               @relation("UserConsent")
  dataSubjectRequests DataSubjectRequest[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Gênero / classificação da obra (ex.: Romance Espírita, Codificação)
model Category {
  id    String @id @default(cuid())
  name  String @unique
  books Book[]
}

model Book {
  id              String          @id @default(cuid())
  workNumber      Int?            @unique
  catalogNumber   String?         @unique
  authorGroup     String?
  title           String
  subtitle        String?
  author          String
  medium          String?
  workType        SpiritWorkType?
  isbn            String?         @unique
  publisher       String?
  year            Int?
  edition         String?
  collection      String?
  pages           Int?
  language        String?
  synopsis        String?
  notes           String?
  coverImageUrl   String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  copies          Copy[]
  categories      Category[]
  loanRequests    LoanRequest[]
}

model Copy {
  id           String     @id @default(cuid())
  bookId       String
  code         String     @unique
  legacyNumber Int?
  shelfOrder   Int?
  status       CopyStatus @default(AVAILABLE)
  book         Book       @relation(fields: [bookId], references: [id], onDelete: Cascade)
  loans        Loan[]

  @@index([legacyNumber])
  @@index([shelfOrder])
}

model Loan {
  id          String       @id @default(cuid())
  copyId      String
  userId      String
  loanDate    DateTime     @default(now())
  dueDate     DateTime
  returnDate  DateTime?
  status      LoanStatus   @default(ACTIVE)
  copy        Copy         @relation(fields: [copyId], references: [id])
  user        User         @relation(fields: [userId], references: [id])
  loanRequest LoanRequest?
}

model LoanRequest {
  id           String            @id @default(cuid())
  userId       String
  bookId       String
  status       LoanRequestStatus @default(PENDING)
  readerNote   String?
  adminNote    String?
  reviewedById String?
  reviewedAt   DateTime?
  loanId       String?           @unique
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  book       Book  @relation(fields: [bookId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("LoanRequestReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  loan       Loan? @relation(fields: [loanId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([bookId])
}

model AppConfig {
  id                   String @id @default("default")
  loanDaysDefault      Int    @default(14)
  institutionName      String @default("Centro Espírita")
  institutionAddress   String?
  institutionEmail     String @default("privacidade@biblioteca.local")
  dpoName              String?
  dpoEmail             String @default("privacidade@biblioteca.local")
  privacyPolicyVersion String  @default("1.0")
  termsVersion         String  @default("1.0")
  institutionLogoUrl   String? @default("/feabe-logo.jpeg")
}

model DataSubjectRequest {
  id          String                   @id @default(cuid())
  userId      String
  type        DataSubjectRequestType
  status      DataSubjectRequestStatus @default(PENDING)
  description String?
  response    String?
  handledById String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  user        User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

/// Código de 6 dígitos para validar e-mail no cadastro
model EmailVerification {
  id           String                   @id @default(cuid())
  email        String
  codeHash     String
  purpose      EmailVerificationPurpose @default(USER_SIGNUP)
  payload      String
  attempts     Int                      @default(0)
  expiresAt    DateTime
  verifiedAt   DateTime?
  createdById  String?
  createdAt    DateTime                 @default(now())

  @@index([email])
  @@index([expiresAt])
}
