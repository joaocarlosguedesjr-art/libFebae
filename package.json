{
  "name": "biblioteca-app",
  "version": "0.0.2",
  "private": true,
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:clean": "node scripts/dev-clean.mjs",
    "dev:stop": "node scripts/dev-stop.mjs",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "node scripts/postinstall.mjs",
    "db:generate": "node scripts/with-env.mjs prisma generate",
    "db:migrate": "node scripts/with-env.mjs prisma migrate dev",
    "db:migrate:deploy": "node scripts/with-env.mjs prisma migrate deploy",
    "db:push": "node scripts/with-env.mjs prisma db push",
    "db:seed": "node scripts/with-env.mjs tsx prisma/seed.ts",
    "db:setup": "node scripts/db-setup.mjs",
    "db:studio": "node scripts/with-env.mjs prisma studio",
    "admin:create": "node scripts/with-env.mjs node scripts/create-admin.mjs",
    "institution:init": "node scripts/with-env.mjs tsx scripts/init-institution.ts",
    "catalog:analyze": "node scripts/analyze-feabe-xlsx.mjs",
    "catalog:enrich": "tsx scripts/enrich-feabe-catalog.ts",
    "catalog:reorganize": "tsx scripts/reorganize-feabe-catalog.ts",
    "catalog:sync:plan": "node scripts/with-env.mjs tsx scripts/sync-feabe-catalog-db.ts --plan",
    "catalog:sync:verify": "node scripts/with-env.mjs tsx scripts/sync-feabe-catalog-db.ts --plan --skip-csv-write",
    "catalog:sync": "node scripts/with-env.mjs tsx scripts/sync-feabe-catalog-db.ts",
    "catalog:sync:dry": "node scripts/with-env.mjs tsx scripts/sync-feabe-catalog-db.ts --plan",
    "dns:verify": "node scripts/verify-dns.mjs",
    "catalog:import": "node scripts/with-env.mjs tsx scripts/import-feabe-catalog.ts",
    "catalog:import:dry": "node scripts/with-env.mjs tsx scripts/import-feabe-catalog.ts --dry-run"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^6.19.3",
    "@tanstack/react-query": "^5.101.2",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^7.0.13",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.22.5",
    "typescript": "^5"
  }
}
